TELEGRAM_BOT_TOKEN=your_telegram_bot_token
GROQ_API_KEY=your_groq_api_key
# Для видео до 200 MB–2 GB: взять на https://my.telegram.org (опционально)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Лимит файла из Telegram (MB). Без ID/HASH — макс. 20.
MAX_VIDEO_SIZE_MB=20
# Лимит скачивания по ссылке (MB). Google Drive / Яндекс.Диск.
MAX_URL_DOWNLOAD_MB=1024
FREE_VIDEO_LIMIT=2
ADMIN_USER_ID=0
PRICE_RUB=99
SUB_DAYS=30
REFERRAL_BONUS=3
MAX_CONCURRENT_RENDERS=2
# Оставь пустым для ручной оплаты (реквизиты + подтверждение админом).
# ЮKassa через BotFather → Payments → Connect ЮKassa → скопируй provider token
PAYMENT_PROVIDER_TOKEN=
PAYMENT_VAT_CODE=1
PAYMENT_TAX_SYSTEM_CODE=2
# Реквизиты для ручной оплаты (показываются пользователю)
PAYMENT_INFO=Переведи 99р по СБП на +7XXXXXXXXXX (Банк). После оплаты пришли чек и нажми «Я оплатил».
